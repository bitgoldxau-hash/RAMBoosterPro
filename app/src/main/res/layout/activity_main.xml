<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1A"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ RAM Booster Pro"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Boost your reported RAM to unlock apps"
            android:textColor="#7C7C9E"
            android:textSize="13sp"
            android:layout_marginBottom="20dp"/>

        <!-- Boosted Status -->
        <TextView
            android:id="@+id/tv_boosted_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checking..."
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="14dp"
            android:background="#16162A"
            android:layout_marginBottom="12dp"/>

        <!-- RAM Info Cards -->
        <TextView
            android:id="@+id/tv_physical_ram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Physical RAM: ..."
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:padding="12dp"
            android:background="#16162A"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_free_ram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Free RAM: ..."
            android:textColor="#48CAE4"
            android:textSize="14sp"
            android:padding="12dp"
            android:background="#16162A"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_total_ram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reported RAM: ..."
            android:textColor="#6C63FF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:background="#16162A"
            android:layout_marginBottom="12dp"/>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_ram"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:max="100"
            android:progress="60"
            android:progressTint="#6C63FF"
            android:progressBackgroundTint="#2A2A3E"
            android:layout_marginBottom="20dp"/>

        <!-- Boost Target Slider -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SELECT BOOST TARGET"
            android:textColor="#5A5A7E"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tv_vram_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Boost to: 10 GB"
            android:textColor="#6C63FF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <SeekBar
            android:id="@+id/seekbar_vram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="12"
            android:progress="10"
            android:progressTint="#6C63FF"
            android:thumbTint="#6C63FF"
            android:layout_marginBottom="20dp"/>

        <!-- Boost Button -->
        <Button
            android:id="@+id/btn_boost"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⚡ BOOST RAM"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#6C63FF"
            android:layout_marginBottom="10dp"/>

        <!-- Reset Button -->
        <Button
            android:id="@+id/btn_reset"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="↩ Reset RAM"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:backgroundTint="#2A2A3E"
            android:layout_marginBottom="20dp"/>

        <!-- Instructions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HOW TO USE"
            android:textColor="#5A5A7E"
            android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Set boost target to 10 GB or more\n2. Tap BOOST RAM button\n3. Open the RAM Test App\n4. It will now show ✅ Allowed!"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.5"
            android:padding="12dp"
            android:background="#16162A"/>

    </LinearLayout>
</ScrollView>
